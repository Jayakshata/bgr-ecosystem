[
  {
    "id": "seg01",
    "file": "assets/audio/vo/seg01.mp3",
    "rate": "-14%",
    "text": "The B G R Ecosystem."
  },
  {
    "id": "seg02",
    "file": "assets/audio/vo/seg02.mp3",
    "rate": "-10%",
    "text": "From the land that makes the products... to the land that makes the makers."
  },
  {
    "id": "seg03",
    "file": "assets/audio/vo/seg03.mp3",
    "rate": "-8%",
    "text": "Every factory begins as empty ground."
  },
  {
    "id": "seg04",
    "file": "assets/audio/vo/seg04.mp3",
    "rate": "-8%",
    "text": "And the world needs more of them than ever."
  },
  {
    "id": "seg05",
    "file": "assets/audio/vo/seg05.mp3",
    "rate": "-6%",
    "text": "But every factory requires..."
  },
  {
    "id": "seg06",
    "file": "assets/audio/vo/seg06.mp3",
    "rate": "-4%",
    "text": "Land."
  },
  {
    "id": "seg07",
    "file": "assets/audio/vo/seg07.mp3",
    "rate": "-4%",
    "text": "Design."
  },
  {
    "id": "seg08",
    "file": "assets/audio/vo/seg08.mp3",
    "rate": "-4%",
    "text": "Water."
  },
  {
    "id": "seg09",
    "file": "assets/audio/vo/seg09.mp3",
    "rate": "-4%",
    "text": "Cooling."
  },
  {
    "id": "seg10",
    "file": "assets/audio/vo/seg10.mp3",
    "rate": "-4%",
    "text": "Steel."
  },
  {
    "id": "seg11",
    "file": "assets/audio/vo/seg11.mp3",
    "rate": "-4%",
    "text": "Power."
  },
  {
    "id": "seg12",
    "file": "assets/audio/vo/seg12.mp3",
    "rate": "-4%",
    "text": "Machines."
  },
  {
    "id": "seg13",
    "file": "assets/audio/vo/seg13.mp3",
    "rate": "-8%",
    "text": "And a thousand approvals."
  },
  {
    "id": "seg14",
    "file": "assets/audio/vo/seg14.mp3",
    "rate": "-18%",
    "text": "What if... one hand... could build it all?"
  },
  {
    "id": "seg15",
    "file": "assets/audio/vo/seg15.mp3",
    "rate": "-14%",
    "text": "Welcome... to the B G R Ecosystem."
  },
  {
    "id": "seg16",
    "file": "assets/audio/vo/seg16.mp3",
    "rate": "-12%",
    "text": "One window. One partner. Land... to handover."
  },
  {
    "id": "seg17",
    "file": "assets/audio/vo/seg17.mp3",
    "rate": "-10%",
    "text": "From bare land... to a running factory."
  },
  {
    "id": "seg18",
    "file": "assets/audio/vo/seg18.mp3",
    "rate": "-8%",
    "text": "Made possible through the partnership of..."
  },
  {
    "id": "seg19",
    "file": "assets/audio/vo/seg19.mp3",
    "rate": "-6%",
    "text": "Anita. Nikitha. Enexio. And B G R NEO."
  },
  {
    "id": "seg20",
    "file": "assets/audio/vo/seg20.mp3",
    "rate": "-16%",
    "text": "First... the factory is born in light."
  },
  {
    "id": "seg21",
    "file": "assets/audio/vo/seg21.mp3",
    "rate": "-6%",
    "text": "Anita, our in-house physical A I team, designs, simulates and commissions the entire factory as a living digital twin — before a single beam is raised."
  },
  {
    "id": "seg22",
    "file": "assets/audio/vo/seg22.mp3",
    "rate": "-16%",
    "text": "Then... it rises in steel."
  },
  {
    "id": "seg23",
    "file": "assets/audio/vo/seg23.mp3",
    "rate": "-6%",
    "text": "Nikitha builds it. Thirty-one years of engineering. Twenty-four thousand tonnes, every year. The hands behind Samsung, Hyundai, and Bengaluru Airport."
  },
  {
    "id": "seg24",
    "file": "assets/audio/vo/seg24.mp3",
    "rate": "-16%",
    "text": "Then... it breathes."
  },
  {
    "id": "seg25",
    "file": "assets/audio/vo/seg25.mp3",
    "rate": "-10%",
    "text": "Tamil Nadu is water-scarce? No matter. Enexio cools... without water."
  },
  {
    "id": "seg26",
    "file": "assets/audio/vo/seg26.mp3",
    "rate": "-16%",
    "text": "And then... it comes alive."
  },
  {
    "id": "seg27",
    "file": "assets/audio/vo/seg27.mp3",
    "rate": "-6%",
    "text": "B G R NEO brings the robots, the automation, the intelligence. Trusted by A B B, Caterpillar, and Lockheed Martin."
  },
  {
    "id": "seg28",
    "file": "assets/audio/vo/seg28.mp3",
    "rate": "-10%",
    "text": "From bare land... to a living factory. One ecosystem."
  },
  {
    "id": "seg29",
    "file": "assets/audio/vo/seg29.mp3",
    "rate": "-18%",
    "text": "Our path... is no longer found."
  },
  {
    "id": "seg30",
    "file": "assets/audio/vo/seg30.mp3",
    "rate": "-20%",
    "text": "It is made."
  }
]